# wog.ch auto-buyer — VPS environment.
# Copy to ".env" ON THE VPS ONLY and fill in. Never commit the real .env.
# Load it before running the notifier, e.g.:  set -a; . ./.env; set +a; python notifier.py

# --- delivery (same as the notifier already uses) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# --- who may reply BUY, and with which wog account (VPS only) ---
# Reply-BUY authorizes by the *sender's Telegram user ID*, so in a group chat
# only listed people can buy — each with their own wog login.
#
# Simple one-person case: set your Telegram USER id here (get it from
# @userinfobot — it's the positive number, NOT the group chat id) plus your wog
# login below. That makes you the sole authorized buyer.
WOG_OWNER_TELEGRAM_ID=
WOG_USERNAME=
WOG_PASSWORD=
#
# Multiple people: instead of the three lines above, create buyers.json (copy
# buyers.json.example) with one entry per person — their Telegram id + their own
# wog login. buyers.json is git-ignored. It takes precedence over the vars above.

# --- auto-buyer behaviour ---
# Master switch. Leave UNSET (or 0) for a dry run that only pings "would buy".
# WOG_BUY_ENABLED=1

# Dry-run activation without arming: set this to exercise the buyer path and get
# "would buy" pings while WOG_BUY_ENABLED stays off. (Either var activates it.)
WOG_BUY_DRYRUN=1

# cart  = add-to-cart + ping you to tap Pay (safe default, works today).
# auto  = also place the invoice order (available after the one-time checkout
#         recon on the VPS — see README "Auto-buyer").
WOG_BUY_MODE=cart

# --- reply-BUY (the normal control) ---
# When a wog.ch alert arrives on Telegram, REPLY to it with "BUY" and the bot
# buys that exact item (English only, price cap enforced) and replies with the
# result. This is on automatically whenever WOG_BUY_ENABLED or WOG_BUY_DRYRUN
# is set and Telegram is configured — no extra flag needed.

# --- keyword full-auto (optional, unattended) ---
# Set to 1 to ALSO auto-buy any fresh wog item matching WOG_BUY_KEYWORDS with no
# reply needed. Leave unset to rely purely on reply-BUY (recommended).
# WOG_AUTOBUY_KEYWORDS=1
# For keyword auto-buy: title/series must contain ONE of these (comma list).
WOG_BUY_KEYWORDS=30th,celebration

# Language marker every buy requires (wog keeps it in seriesName).
WOG_BUY_LANG_MARKER=-EN-
# Hard per-item price ceiling in CHF. Anything above is refused.
WOG_BUY_MAX_PRICE=300
# One-order-per-product ledger file.
WOG_BUY_LEDGER=bought.json

# Poll faster on a private box (the 30s public-runner floor doesn't apply).
POLL_SECONDS=8
