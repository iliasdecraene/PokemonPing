# wog.ch auto-buyer — VPS environment.
# Copy to ".env" ON THE VPS ONLY and fill in. Never commit the real .env.
# Load it before running the notifier, e.g.:  set -a; . ./.env; set +a; python notifier.py

# --- delivery (same as the notifier already uses) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# --- wog login (VPS only — keeps creds off the public repo/runner) ---
WOG_USERNAME=
WOG_PASSWORD=

# --- auto-buyer behaviour ---
# Master switch. Leave UNSET (or 0) for a dry run that only pings "would buy".
# WOG_BUY_ENABLED=1

# Dry-run activation without arming: set this to exercise the buyer path and get
# "would buy" pings while WOG_BUY_ENABLED stays off. (Either var activates it.)
WOG_BUY_DRYRUN=1

# cart  = add-to-cart + ping you to tap Pay (safe default, works today).
# auto  = also place the invoice order (available after the one-time checkout
#         recon on the VPS — see README "Auto-buyer").
WOG_BUY_MODE=cart

# A product's title/series must contain ONE of these (comma list).
WOG_BUY_KEYWORDS=30th,celebration
# ...and this language marker (wog keeps it in seriesName).
WOG_BUY_LANG_MARKER=-EN-
# Hard per-item price ceiling in CHF. Anything above is refused.
WOG_BUY_MAX_PRICE=300
# One-order-per-product ledger file.
WOG_BUY_LEDGER=bought.json

# Poll faster on a private box (the 30s public-runner floor doesn't apply).
POLL_SECONDS=8
